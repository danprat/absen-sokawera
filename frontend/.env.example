# Supabase transition config (public browser-safe values only)
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=<publishable-key>
# Legacy anon key fallback is also supported:
# VITE_SUPABASE_ANON_KEY=<anon-key>

# Module Edge Functions
VITE_AUTH_API_URL=https://<project-ref>.supabase.co/functions/v1/auth-api
VITE_PUBLIC_API_URL=https://<project-ref>.supabase.co/functions/v1/public-api
VITE_EMPLOYEES_API_URL=https://<project-ref>.supabase.co/functions/v1/employees-api
VITE_ATTENDANCE_API_URL=https://<project-ref>.supabase.co/functions/v1/attendance-api
VITE_ADMIN_SETTINGS_API_URL=https://<project-ref>.supabase.co/functions/v1/admin-settings-api
VITE_ADMIN_REPORTS_API_URL=https://<project-ref>.supabase.co/functions/v1/admin-reports-api
VITE_AUDIT_API_URL=https://<project-ref>.supabase.co/functions/v1/audit-api
VITE_ADMINS_API_URL=https://<project-ref>.supabase.co/functions/v1/admins-api
VITE_GUESTBOOK_API_URL=https://<project-ref>.supabase.co/functions/v1/guestbook-api
VITE_SURVEY_API_URL=https://<project-ref>.supabase.co/functions/v1/survey-api
VITE_FACE_ORCHESTRATOR_URL=https://<project-ref>.supabase.co/functions/v1/face-orchestrator
# Local Edge Function test:
# VITE_FACE_ORCHESTRATOR_URL=http://127.0.0.1:54321/functions/v1/face-orchestrator

# Legacy fallback only. Keep unset for production module API deployments.
# VITE_API_BASE_URL=https://<project-ref>.supabase.co/functions/v1/app-api
