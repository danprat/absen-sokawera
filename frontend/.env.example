# API Backend URL
VITE_API_BASE_URL=https://<project-ref>.supabase.co/functions/v1/app-api

# Supabase transition config (public browser-safe values only)
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=<publishable-key>
# Legacy anon key fallback is also supported:
# VITE_SUPABASE_ANON_KEY=<anon-key>
VITE_FACE_ORCHESTRATOR_URL=https://<project-ref>.supabase.co/functions/v1/app-api/api/v1
# Local Edge Function test:
# VITE_FACE_ORCHESTRATOR_URL=http://127.0.0.1:54321/functions/v1/face-orchestrator
